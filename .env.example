# ---------------------------------------------------------------------------
# Alma Solo Travel — environment variables
# Copy this file to `.env.local` and fill in real values before production.
# Nothing here is required to run `npm run dev`; the enquiry form and
# newsletter fall back to a local mock when these are absent.
# ---------------------------------------------------------------------------

# Public site URL — used for canonical URLs, sitemap and Open Graph.
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# --- Email delivery (enquiry + newsletter) -------------------------------
# e.g. Resend, Postmark, SendGrid. Leave blank to use the built-in mock.
EMAIL_PROVIDER_API_KEY=""
ENQUIRY_NOTIFY_ADDRESS="hello@almasolotravel.com"

# --- CRM (optional) -------------------------------------------------------
CRM_API_KEY=""

# --- Analytics (optional) -------------------------------------------------
NEXT_PUBLIC_ANALYTICS_ID=""
